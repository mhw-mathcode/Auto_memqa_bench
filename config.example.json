{
  "pipeline": {
    "input_dir": "dataset",
    "output_dir": "result",
    "temp_dir": "temp",
    "max_workers": 4,
    "version_prefix": "v"
  },
  "steps": {
    "step_0_generate_qa": {
      "function": "generate_qa_v0",
      "api_required": true,
      "description": "步骤 0: 生成原始问答对",
      "llm": {
        "model": "qwen3-14b",
        "base_url": "https://api.example.com/v1",
        "api_key": "YOUR_API_KEY_HERE"
      }
    },
    "step_1_full_context": {
      "function": "evidence_check_main",
      "api_required": true,
      "description": "步骤 1: 题目合理性检测 (v0 -> v1)",
      "llm": {
        "model": "qwen3-14b",
        "base_url": "https://api.example.com/v1",
        "api_key": "YOUR_API_KEY_HERE"
      }
    },
    "step_2_label": {
      "function": "label_main",
      "api_required": true,
      "description": "步骤 2: 题目标注 (v1 -> v2)",
      "llm": {
        "model": "qwen3-14b",
        "base_url": "https://api.example.com/v1",
        "api_key": "YOUR_API_KEY_HERE"
      }
    },
    "step_3_new_qa": {
      "function": "new_qa_main",
      "api_required": true,
      "description": "步骤 3: 问答精炼重构 (v2 -> v3)",
      "llm": {
        "model": "qwen3-14b",
        "base_url": "https://api.example.com/v1",
        "api_key": "YOUR_API_KEY_HERE"
      }
    },
    "step_4_pollution_check": {
      "function": "pollution_check_main",
      "api_required": true,
      "description": "步骤 4: 题目乱序和污染检查 (v3 -> v4)",
      "enable_contamination_check": true,
      "cleanup_temp_files": true,
      "llm": {
        "model": "qwen3-14b",
        "base_url": "https://api.example.com/v1",
        "api_key": "YOUR_API_KEY_HERE"
      }
    }
  },
  "tools": {
    "option_perturbation": {
      "function": "option_perturbation",
      "api_required": true,
      "description": "选项扰动生成和评分",
      "llm": {
        "gen_model": "Qwen/Qwen3-14B",
        "score_model": "Qwen/Qwen2.5-7B-Instruct",
        "base_url": "https://api.example.com/v1",
        "api_key": "YOUR_API_KEY_HERE"
      }
    }
  }
}
